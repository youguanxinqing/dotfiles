#!/usr/bin/env bash
# Swap the scratch pane and the main pane (position + size).
# If scratch pane is not visible, do nothing.

current_window=$(tmux display-message -p '#{window_id}')
current_pane=$(tmux display-message -p '#{pane_id}')

# Find the scratch pane
scratch_id=$(tmux list-panes -t "$current_window" -F '#{pane_id}:#{@scratch}' | grep ":1$" | head -1 | cut -d: -f1)

if [ -z "$scratch_id" ]; then
    tmux display-message "No scratch pane in this window"
    exit 0
fi

owner_id=$(tmux display-message -p -t "$scratch_id" '#{@scratch_owner}')

if [ "$current_pane" = "$scratch_id" ]; then
    main_id="$owner_id"
elif [ -n "$owner_id" ] && [ "$current_pane" = "$owner_id" ]; then
    main_id="$owner_id"
else
    tmux display-message "Current pane is not bound to scratch"
    exit 0
fi

if [ -z "$main_id" ]; then
    tmux display-message "No swap target for scratch pane"
    exit 0
fi

# Swap position and size
tmux swap-pane -s "$scratch_id" -t "$main_id"
