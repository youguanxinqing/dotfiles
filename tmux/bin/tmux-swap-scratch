#!/usr/bin/env bash
# Swap the scratch pane and the main pane (position + size).
# If scratch pane is not visible, do nothing.

# Find the scratch pane
scratch_id=$(tmux list-panes -F '#{pane_id}:#{@scratch}' | grep ":1$" | head -1 | cut -d: -f1)

if [ -z "$scratch_id" ]; then
    tmux display-message "No scratch pane in this window"
    exit 0
fi

current_id=$(tmux display -p '#{pane_id}')

# Pick the main pane (the non-scratch one)
if [ "$current_id" = "$scratch_id" ]; then
    main_id=$(tmux list-panes -F '#{pane_id}:#{@scratch}' | grep -v ":1$" | head -1 | cut -d: -f1)
else
    main_id="$current_id"
fi

main_height=$(tmux display -p -t "$main_id" '#{pane_height}')

# Swap position and size
tmux swap-pane -s "$scratch_id" -t "$main_id"
